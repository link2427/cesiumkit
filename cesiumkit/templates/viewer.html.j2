<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>{{ title }}</title>
    <script src="https://cesium.com/downloads/cesiumjs/releases/{{ cesium_version }}/Build/Cesium/Cesium.js"></script>
    <link href="https://cesium.com/downloads/cesiumjs/releases/{{ cesium_version }}/Build/Cesium/Widgets/widgets.css" rel="stylesheet">
    <style>
        html, body, #{{ container_id }} {
            width: {{ width }};
            height: {{ height }};
            margin: 0;
            padding: 0;
            overflow: hidden;
        }
    </style>
</head>
<body>
    <div id="{{ container_id }}"></div>
    <script>
        {% if ion_token %}
        Cesium.Ion.defaultAccessToken = '{{ ion_token }}';
        {% endif %}

        {% if not ion_token %}
        // No Ion token -- explicitly set the base imagery layer to the
        // NaturalEarthII tiles that Cesium ships on its CDN. We deliberately
        // avoid `ImageryLayer.fromProviderAsync(...)` here: in headless
        // chromium the promise chain was leaving the layer stuck with no
        // attached provider, and the globe rendered as empty skybox. Using
        // UrlTemplateImageryProvider with a direct template URL bypasses
        // the async path entirely -- the provider is ready the moment it's
        // constructed.
        const _naturalEarthUrl = Cesium.buildModuleUrl("Assets/Textures/NaturalEarthII/") + "{z}/{x}/{reverseY}.jpg";
        const viewerOptions = Object.assign({{ viewer_options }}, {
            baseLayer: new Cesium.ImageryLayer(
                new Cesium.UrlTemplateImageryProvider({
                    url: _naturalEarthUrl,
                    tilingScheme: new Cesium.GeographicTilingScheme(),
                    maximumLevel: 2,
                    credit: "Natural Earth II"
                })
            ),
            baseLayerPicker: false,
            geocoder: false,
        });
        {% else %}
        const viewerOptions = {{ viewer_options }};
        {% endif %}

        const viewer = new Cesium.Viewer('{{ container_id }}', viewerOptions);
        // Expose the viewer on window so external tools (playwright, devtools,
        // custom scripts) can reach it. `const` is script-scoped so we need
        // to attach it explicitly.
        window.viewer = viewer;

        // Allow scripts in the InfoBox iframe to suppress sandbox warnings
        if (viewer.infoBox) {
            viewer.infoBox.frame.removeAttribute('sandbox');
            viewer.infoBox.frame.src = 'about:blank';
        }

        {% for stmt in scene_statements %}
        {{ stmt }}
        {% endfor %}

        {% for stmt in globe_statements %}
        {{ stmt }}
        {% endfor %}

        {% for stmt in clock_statements %}
        {{ stmt }}
        {% endfor %}

        {% for entity_js in entities %}
        viewer.entities.add({{ entity_js }});
        {% endfor %}

        {% for ds_js in data_sources %}
        viewer.dataSources.add({{ ds_js }});
        {% endfor %}

        {% for tileset_js in tilesets %}
        (async () => {
            try {
                const tileset = await {{ tileset_js }};
                viewer.scene.primitives.add(tileset);
            } catch (error) {
                console.error('Error loading tileset:', error);
            }
        })();
        {% endfor %}

        {% for camera_op in camera_operations %}
        {{ camera_op }}
        {% endfor %}

        {% for event_js in event_handlers %}
        {{ event_js }};
        {% endfor %}

        {% for custom_js in custom_scripts %}
        {{ custom_js }}
        {% endfor %}
    </script>
</body>
</html>
